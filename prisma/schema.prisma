generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Job {
  id            String      @id @default(cuid())
  jobNumber     String      @default("")
  title         String
  customer      String      @default("")
  jobType       String      @default("")
  address       String      @default("")
  jobLead       String      @default("")
  siteContact   String      @default("")
  startDate     DateTime
  endDate       DateTime
  startTime     String?
  description   String      @default("")
  colorTag      String      @default("#3B82F6")
  legacyJobUrl  String?
  googleEventId String?     @unique
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  photos            Photo[]
  dailyAssignments  DailyAssignment[]
  boardCards        BoardCard[]
}

model BoardCard {
  id        String   @id @default(cuid())
  date      String
  jobId     String?
  job       Job?     @relation(fields: [jobId], references: [id], onDelete: SetNull)
  label     String   @default("")
  color     String   @default("#3B82F6")
  x         Float    @default(0)
  y         Float    @default(0)
  width     Float    @default(200)
  crew      String   @default("[]")
  truck     String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Photo {
  id          String   @id @default(cuid())
  jobId       String
  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  url         String
  caption     String   @default("")
  uploadedBy  String   @default("crew")
  uploadedAt  DateTime @default(now())
}

model CrewOff {
  id        String   @id @default(cuid())
  crewName  String
  startDate DateTime
  endDate   DateTime
  note      String   @default("")
  createdAt DateTime @default(now())
}

model CrewMember {
  id   String @id @default(cuid())
  name String @unique
}

model DailyAssignment {
  id          String   @id @default(cuid())
  date        DateTime
  jobId       String
  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  crewMembers String   @default("[]")
  truck       String   @default("")
  notes       String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([date, jobId])
}

model WeekTask {
  id         String   @id @default(cuid())
  weekOf     String
  title      String
  color      String   @default("#94A3B8")
  assignedTo String   @default("")
  done       Boolean  @default(false)
  createdAt  DateTime @default(now())
}
