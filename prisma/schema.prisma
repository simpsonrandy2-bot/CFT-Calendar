generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

model Job {
  id            String   @id @default(cuid())
  jobNumber     String   @default("")
  title         String
  customer      String   @default("")
  jobType       String   @default("")
  address       String   @default("")
  jobLead       String   @default("")
  siteContact   String   @default("")
  startDate     DateTime
  endDate       DateTime
  startTime     String?
  description   String   @default("")
  colorTag      String   @default("#3B82F6")
  legacyJobUrl  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  photos        Photo[]
}

model Photo {
  id          String   @id @default(cuid())
  jobId       String
  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  url         String
  caption     String   @default("")
  uploadedBy  String   @default("crew")
  uploadedAt  DateTime @default(now())
}

model CrewOff {
  id        String   @id @default(cuid())
  crewName  String
  startDate DateTime
  endDate   DateTime
  note      String   @default("")
  createdAt DateTime @default(now())
}

model CrewMember {
  id   String @id @default(cuid())
  name String @unique
}
